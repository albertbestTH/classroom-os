{
  "name": "classroom-os",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:generate": "pnpm --filter @classroom-os/database db:generate",
    "db:format": "pnpm --filter @classroom-os/database db:format",
    "db:validate": "pnpm --filter @classroom-os/database db:validate",
    "db:migrate": "pnpm --filter @classroom-os/database db:migrate",
    "db:migrate:status": "pnpm --filter @classroom-os/database db:migrate:status",
    "db:bootstrap:auth": "pnpm --filter @classroom-os/database db:bootstrap:auth",
    "db:studio": "pnpm --filter @classroom-os/database db:studio",
    "db:test": "pnpm --filter @classroom-os/database db:test",
    "api:test": "pnpm --filter web test"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
