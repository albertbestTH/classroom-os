generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  runtime             = "nodejs"
  moduleFormat        = "esm"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  school_admin
  teacher
}

enum SessionStatus {
  scheduled
  live
  completed
  cancelled
}

enum AttendanceStatus {
  present
  late
  absent
  leave
}

enum AssessmentType {
  quiz
  homework
  exam
  project
  participation
  other
}

model School {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  code      String   @unique
  timezone  String   @default("Asia/Bangkok")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  academicYears       AcademicYear[]
  terms               Term[]
  users               User[]
  teachers            Teacher[]
  students            Student[]
  classrooms          Classroom[]
  subjects            Subject[]
  classEnrollments    ClassEnrollment[]
  teachingAssignments TeachingAssignment[]
  timetableEntries    TimetableEntry[]
  classSessions       ClassSession[]
  attendanceRecords   AttendanceRecord[]
  assessments         Assessment[]
  scores              Score[]
  auditLogs           AuditLog[]

  @@index([isActive])
}

model AcademicYear {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String   @db.Uuid
  name      String
  startsOn  DateTime @db.Date
  endsOn    DateTime @db.Date
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  school School @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  terms  Term[]

  @@unique([schoolId, name])
  @@index([schoolId, isCurrent])
  @@index([schoolId, startsOn, endsOn])
}

model Term {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId       String   @db.Uuid
  academicYearId String   @db.Uuid
  name           String
  startsOn       DateTime @db.Date
  endsOn         DateTime @db.Date
  isCurrent      Boolean  @default(false)
  createdAt      DateTime @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @db.Timestamptz(3)

  school              School               @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  academicYear        AcademicYear         @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  classEnrollments    ClassEnrollment[]
  teachingAssignments TeachingAssignment[]
  timetableEntries    TimetableEntry[]
  classSessions       ClassSession[]
  assessments         Assessment[]

  @@unique([academicYearId, name])
  @@index([schoolId, isCurrent])
  @@index([schoolId, startsOn, endsOn])
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String   @db.Uuid
  email     String
  firstName String
  lastName  String
  role      UserRole
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  school                    School             @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  teacherProfile            Teacher?           @relation("TeacherUser")
  recordedAttendanceRecords AttendanceRecord[] @relation("AttendanceRecorder")
  auditLogs                 AuditLog[]         @relation("AuditActor")

  @@unique([schoolId, email])
  @@index([schoolId, role, isActive])
}

model Teacher {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId     String   @db.Uuid
  userId       String?  @unique @db.Uuid
  employeeCode String
  firstName    String
  lastName     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @db.Timestamptz(3)

  school              School               @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  user                User?                @relation("TeacherUser", fields: [userId], references: [id], onDelete: SetNull)
  homeroomClassrooms  Classroom[]          @relation("HomeroomTeacher")
  teachingAssignments TeachingAssignment[]
  timetableEntries    TimetableEntry[]
  classSessions       ClassSession[]
  assessments         Assessment[]         @relation("AssessmentTeacher")
  gradedScores        Score[]              @relation("ScoreGrader")

  @@unique([schoolId, employeeCode])
  @@index([schoolId, isActive])
}

model Student {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId      String    @db.Uuid
  studentNumber String
  firstName     String
  lastName      String
  preferredName String?
  dateOfBirth   DateTime? @db.Date
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(3)

  school            School             @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  classEnrollments  ClassEnrollment[]
  attendanceRecords AttendanceRecord[]
  scores            Score[]

  @@unique([schoolId, studentNumber])
  @@index([schoolId, lastName, firstName])
  @@index([schoolId, isActive])
}

model Classroom {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId          String   @db.Uuid
  homeroomTeacherId String?  @db.Uuid
  code              String
  name              String
  gradeLevel        String
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  school              School               @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  homeroomTeacher     Teacher?             @relation("HomeroomTeacher", fields: [homeroomTeacherId], references: [id], onDelete: SetNull)
  classEnrollments    ClassEnrollment[]
  teachingAssignments TeachingAssignment[]
  timetableEntries    TimetableEntry[]
  classSessions       ClassSession[]
  assessments         Assessment[]

  @@unique([schoolId, code])
  @@index([schoolId, gradeLevel, isActive])
  @@index([homeroomTeacherId])
}

model Subject {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String   @db.Uuid
  code      String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  school              School               @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  teachingAssignments TeachingAssignment[]
  timetableEntries    TimetableEntry[]
  classSessions       ClassSession[]
  assessments         Assessment[]

  @@unique([schoolId, code])
  @@index([schoolId, name])
  @@index([schoolId, isActive])
}

model ClassEnrollment {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId    String    @db.Uuid
  termId      String    @db.Uuid
  classroomId String    @db.Uuid
  studentId   String    @db.Uuid
  enrolledAt  DateTime  @default(now()) @db.Timestamptz(3)
  leftAt      DateTime? @db.Timestamptz(3)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  term      Term      @relation(fields: [termId], references: [id], onDelete: Restrict)
  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Restrict)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Restrict)

  @@unique([termId, classroomId, studentId])
  @@index([schoolId, termId, classroomId, isActive])
  @@index([schoolId, termId, studentId])
}

model TeachingAssignment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId    String   @db.Uuid
  termId      String   @db.Uuid
  teacherId   String   @db.Uuid
  classroomId String   @db.Uuid
  subjectId   String   @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  school    School    @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  term      Term      @relation(fields: [termId], references: [id], onDelete: Restrict)
  teacher   Teacher   @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Restrict)
  subject   Subject   @relation(fields: [subjectId], references: [id], onDelete: Restrict)

  @@unique([schoolId, termId, teacherId, classroomId, subjectId])
  @@index([schoolId, termId, teacherId])
  @@index([schoolId, termId, classroomId, subjectId])
}

model TimetableEntry {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId    String   @db.Uuid
  termId      String   @db.Uuid
  teacherId   String   @db.Uuid
  classroomId String   @db.Uuid
  subjectId   String   @db.Uuid
  /// ISO weekday used by the MVP timetable: 1 (Monday) through 5 (Friday).
  weekday     Int
  /// Local wall-clock times interpreted using School.timezone.
  startTime   DateTime @db.Time(0)
  endTime     DateTime @db.Time(0)
  room        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  school        School         @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  term          Term           @relation(fields: [termId], references: [id], onDelete: Restrict)
  teacher       Teacher        @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  classroom     Classroom      @relation(fields: [classroomId], references: [id], onDelete: Restrict)
  subject       Subject        @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  classSessions ClassSession[]

  @@unique([schoolId, termId, weekday, startTime, classroomId])
  @@unique([schoolId, termId, weekday, startTime, teacherId])
  @@index([schoolId, termId, weekday, isActive])
  @@index([schoolId, teacherId, weekday])
  @@index([schoolId, classroomId, weekday])
}

model ClassSession {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId         String        @db.Uuid
  termId           String        @db.Uuid
  timetableEntryId String?       @db.Uuid
  teacherId        String        @db.Uuid
  classroomId      String        @db.Uuid
  subjectId        String        @db.Uuid
  scheduledStart   DateTime      @db.Timestamptz(3)
  scheduledEnd     DateTime      @db.Timestamptz(3)
  startedAt        DateTime?     @db.Timestamptz(3)
  endedAt          DateTime?     @db.Timestamptz(3)
  status           SessionStatus @default(scheduled)
  notes            String?
  createdAt        DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime      @updatedAt @db.Timestamptz(3)

  school            School             @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  term              Term               @relation(fields: [termId], references: [id], onDelete: Restrict)
  timetableEntry    TimetableEntry?    @relation(fields: [timetableEntryId], references: [id], onDelete: SetNull)
  teacher           Teacher            @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  classroom         Classroom          @relation(fields: [classroomId], references: [id], onDelete: Restrict)
  subject           Subject            @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  attendanceRecords AttendanceRecord[]
  assessments       Assessment[]

  @@unique([timetableEntryId, scheduledStart])
  @@index([schoolId, scheduledStart, status])
  @@index([schoolId, teacherId, scheduledStart])
  @@index([schoolId, classroomId, scheduledStart])
}

model AttendanceRecord {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId       String           @db.Uuid
  classSessionId String           @db.Uuid
  studentId      String           @db.Uuid
  recordedById   String?          @db.Uuid
  status         AttendanceStatus
  note           String?
  recordedAt     DateTime         @default(now()) @db.Timestamptz(3)
  createdAt      DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime         @updatedAt @db.Timestamptz(3)

  school       School       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Restrict)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Restrict)
  recordedBy   User?        @relation("AttendanceRecorder", fields: [recordedById], references: [id], onDelete: SetNull)

  @@unique([classSessionId, studentId])
  @@index([schoolId, studentId, recordedAt])
  @@index([schoolId, classSessionId, status])
}

model Assessment {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId       String         @db.Uuid
  termId         String         @db.Uuid
  classroomId    String         @db.Uuid
  subjectId      String         @db.Uuid
  teacherId      String         @db.Uuid
  classSessionId String?        @db.Uuid
  title          String
  type           AssessmentType
  maxScore       Decimal        @db.Decimal(7, 2)
  dueAt          DateTime?      @db.Timestamptz(3)
  createdAt      DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime       @updatedAt @db.Timestamptz(3)

  school       School        @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  term         Term          @relation(fields: [termId], references: [id], onDelete: Restrict)
  classroom    Classroom     @relation(fields: [classroomId], references: [id], onDelete: Restrict)
  subject      Subject       @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  teacher      Teacher       @relation("AssessmentTeacher", fields: [teacherId], references: [id], onDelete: Restrict)
  classSession ClassSession? @relation(fields: [classSessionId], references: [id], onDelete: SetNull)
  scores       Score[]

  @@index([schoolId, termId, classroomId, subjectId])
  @@index([schoolId, teacherId, createdAt])
  @@index([classSessionId])
}

model Score {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId     String   @db.Uuid
  assessmentId String   @db.Uuid
  studentId    String   @db.Uuid
  gradedById   String?  @db.Uuid
  value        Decimal  @db.Decimal(7, 2)
  feedback     String?
  gradedAt     DateTime @default(now()) @db.Timestamptz(3)
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @db.Timestamptz(3)

  school     School     @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Restrict)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Restrict)
  gradedBy   Teacher?   @relation("ScoreGrader", fields: [gradedById], references: [id], onDelete: SetNull)

  @@unique([assessmentId, studentId])
  @@index([schoolId, studentId, gradedAt])
  @@index([schoolId, assessmentId])
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId    String   @db.Uuid
  actorUserId String?  @db.Uuid
  action      String
  entityType  String
  entityId    String   @db.Uuid
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @db.Timestamptz(3)

  school School @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  actor  User?  @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([schoolId, createdAt])
  @@index([schoolId, entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
}
