# Local Docker development only. Never commit production credentials.
DATABASE_URL="postgresql://classroom:classroom_dev_only@localhost:5432/classroom_os?schema=public"

# Per-process login limiter defaults. Distributed deployments require a shared store.
AUTH_LOGIN_RATE_LIMIT_MAX="5"
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS="900000"
AUTH_LOGIN_RATE_LIMIT_MAX_BUCKETS="10000"
